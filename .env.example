NODE_ENV=development
PORT=3000

# PostgreSQL (local or cloud). Render / most hosts require SSL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/simpliss?schema=public"

# --- Option A: Upstash (recommended for serverless / cloud) ---
# REST URL + token from Upstash dashboard; app converts to rediss:// for ioredis + Socket.IO.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_token_here"

# --- Option B: Local or any Redis URL (used when Upstash vars are not both set) ---
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=dev_jwt_access_secret_must_be_at_least_32_chars
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_must_be_at_least_32_chars

CORS_ORIGIN=http://localhost:8080

STORAGE_TYPE=local

QR_BASE_URL=http://localhost:8080

# Optional - required if STORAGE_TYPE=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Optional - required if STORAGE_TYPE=cloudinary
# CLOUDINARY_URL=
